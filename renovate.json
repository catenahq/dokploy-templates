{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(America/Toronto)",
    "helpers:pinGitHubActionDigests"
  ],
  "schedule": ["before 5am"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "prCreation": "not-pending",
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "automerge": true,
    "minimumReleaseAge": null
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm dev-deps (minor+patch)",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm runtime (minor+patch)",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchManagers": ["pep723"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python pep723 (minor+patch)",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "matchManagers": ["docker-compose"],
      "matchFileNames": ["source/compose/**"],
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "groupName": "catalog images (patch+minor)",
      "automerge": true
    },
    {
      "matchManagers": ["docker-compose"],
      "matchFileNames": ["source/compose/**"],
      "matchUpdateTypes": ["major"],
      "groupName": "catalog images (major)",
      "automerge": false
    },
    {
      "description": "Traefik feature-set + config schema owned by Dokploy installer; minor/major land via Dokploy upgrades, not catalog edits.",
      "matchManagers": ["docker-compose"],
      "matchFileNames": ["source/compose/**"],
      "matchPackageNames": ["traefik"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "blueprints/**"
  ]
}
